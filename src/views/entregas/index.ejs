<%- include('../partials/header', { titulo: 'Listagem de Entregas' }) %>

  <div class="deliver-list-container">
    <div class="page-header">
      <h1>Listagem de Entregas</h1>
      <a href="/painel/entregas/novo" class="btn btn-primary">+ Nova Entrega</a>
    </div>

    <% if (typeof sucesso !=='undefined' && sucesso) { %>
      <div class="alert alert-success">
        <p>
          <%= sucesso %>
        </p>
      </div>
      <% } %>

        <form method="GET" action="/painel/entregas" class="filter-bar">
          <div class="filter-group">
            <label for="status">Filtrar por status:</label>
            <select id="status" name="status">
              <option value="" <%=!statusSelecionado ? 'selected' : '' %>>Todos</option>
              <option value="CRIADA" <%=statusSelecionado==='CRIADA' ? 'selected' : '' %>>CRIADA</option>
              <option value="EM_TRANSITO" <%=statusSelecionado==='EM_TRANSITO' ? 'selected' : '' %>>EM TRÂNSITO</option>
              <option value="ENTREGUE" <%=statusSelecionado==='ENTREGUE' ? 'selected' : '' %>>ENTREGUE</option>
              <option value="CANCELADA" <%=statusSelecionado==='CANCELADA' ? 'selected' : '' %>>CANCELADA</option>
            </select>
          </div>
          <button type="submit" class="btn btn-secondary">Filtrar</button>
          <a href="/painel/entregas" class="btn btn-link">Limpar</a>
        </form>

        <div class="data-grid" style="grid-template-columns: 1fr 1fr 1fr 1fr 1fr 1fr 1fr;"
          data-testid="tabela-entregas">
          <div class="data-grid-header">
            <div class="data-grid-cell-header">ID</div>
            <div class="data-grid-cell-header">Descrição</div>
            <div class="data-grid-cell-header">Origem</div>
            <div class="data-grid-cell-header">Destino</div>
            <div class="data-grid-cell-header">Status</div>
            <div class="data-grid-cell-header">Data Criação</div>
            <div class="data-grid-cell-header">Ações</div>
          </div>

          <% if (entregas && entregas.length> 0) { %>
            <% entregas.forEach(entrega=> { %>
              <div class="data-grid-row" data-testid="linha-entrega">
                <div class="data-grid-cell">
                  <strong>
                    <%= entrega.id %>
                  </strong>
                </div>
                <div class="data-grid-cell">
                  <%= entrega.descricao %>
                </div>
                <div class="data-grid-cell">
                  <%= entrega.origem %>
                </div>
                <div class="data-grid-cell">
                  <%= entrega.destino %>
                </div>
                <div class="data-grid-cell">
                  <span class="badge badge-<%= entrega.status.toLowerCase() %>">
                    <%= entrega.status.replace('_', ' ' ) %>
                  </span>
                </div>
                <div class="data-grid-cell">
                  <%= entrega.createdAt ? new Date(entrega.createdAt).toLocaleDateString('pt-BR') : '-' %>
                </div>
                <div class="data-grid-cell">
                  <a href="/painel/entregas/<%= entrega.id %>" class="btn btn-sm btn-outline">Ver Detalhes</a>
                </div>
              </div>
              <% }); %>
                <% } else { %>
                  <div class="data-grid-row"
                    style="grid-column: 1 / -1; justify-content: center; padding: 40px; color: var(--text-muted);">
                    Nenhuma entrega encontrada
                  </div>
                  <% } %>
        </div>

        <div class="pagination">
          <% if (page> 1) { %>
            <a href="/painel/entregas?page=<%= page - 1 %><%= statusSelecionado ? '&status=' + statusSelecionado : '' %>"
              class="btn btn-sm btn-outline">Anterior</a>
            <% } %>

              <span class="page-info">Página <strong>
                  <%= page %>
                </strong> de <%= totalPages %></span>

              <% if (page < totalPages) { %>
                <a href="/painel/entregas?page=<%= page + 1 %><%= statusSelecionado ? '&status=' + statusSelecionado : '' %>"
                  class="btn btn-sm btn-outline">Próxima</a>
                <% } %>
        </div>

        <div class="footer-actions">
          <a href="/painel" class="btn btn-link">&larr; Voltar ao Painel</a>
        </div>
  </div>

  <%- include('../partials/footer') %>