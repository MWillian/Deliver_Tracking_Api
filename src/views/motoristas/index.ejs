<%- include('../partials/header', { titulo: 'Listagem de Motoristas' }) %>

  <div class="deliver-list-container">
    <div class="page-header">
      <h1>Listagem de Motoristas</h1>
      <a href="/painel/motoristas/novo" class="btn btn-primary">+ Novo Motorista</a>
    </div>

    <% if (typeof sucesso !=='undefined' && sucesso) { %>
      <div class="alert alert-success">
        <p>
          <%= sucesso %>
        </p>
      </div>
      <% } else if (locals.flash && flash.sucesso && flash.sucesso.length> 0) { %>
        <div class="alert alert-success">
          <p>
            <%= flash.sucesso[0] %>
          </p>
        </div>
        <% } %>

          <% if (typeof erro !=='undefined' && erro) { %>
            <div class="alert alert-danger">
              <p>
                <%= erro %>
              </p>
            </div>
            <% } else if (locals.flash && flash.erro && flash.erro.length> 0) { %>
              <div class="alert alert-danger">
                <p>
                  <%= flash.erro[0] %>
                </p>
              </div>
              <% } %>
                <form method="GET" action="/painel/motoristas" class="filter-bar">
                  <div class="filter-group">
                    <label for="status">Filtrar por status:</label>
                    <select id="status" name="status">
                      <option value="" <%=!locals.statusSelecionado ? 'selected' : '' %>>Todos</option>
                      <option value="ATIVO" <%=locals.statusSelecionado==='ATIVO' ? 'selected' : '' %>>ATIVO</option>
                      <option value="INATIVO" <%=locals.statusSelecionado==='INATIVO' ? 'selected' : '' %>>INATIVO
                      </option>
                    </select>
                  </div>
                  <button type="submit" class="btn btn-secondary">Filtrar</button>
                  <a href="/painel/motoristas" class="btn btn-link">Limpar</a>
                </form>

                <div class="data-grid" style="grid-template-columns: 1fr 1fr 1fr 1fr 1fr 1fr 1fr;"
                  data-testid="tabela-motoristas">
                  <div class="data-grid-header">
                    <div class="data-grid-cell-header">ID</div>
                    <div class="data-grid-cell-header">Nome</div>
                    <div class="data-grid-cell-header">CPF</div>
                    <div class="data-grid-cell-header">Placa</div>
                    <div class="data-grid-cell-header">Status</div>
                    <div class="data-grid-cell-header">Ações</div>
                    <div class="data-grid-cell-header">Desativar</div>
                  </div>

                  <div id="grid-body" style="display: contents;">
                    <% const lista=locals.motoristas || locals.data; %>
                      <% if (lista && lista.length> 0) { %>
                        <% lista.forEach(motorista=> { %>
                          <div class="data-grid-row" data-testid="linha-motorista">
                            <div class="data-grid-cell"><strong>
                                <%= motorista.id %>
                              </strong></div>
                            <div class="data-grid-cell">
                              <%= motorista.nome %>
                            </div>
                            <div class="data-grid-cell">
                              <%= motorista.cpf %>
                            </div>
                            <div class="data-grid-cell">
                              <%= motorista.placaVeiculo %>
                            </div>
                            <div class="data-grid-cell">
                              <span class="badge badge-<%= motorista.status.toLowerCase() %>">
                                <%= motorista.status %>
                              </span>
                            </div>
                            <div class="data-grid-cell">
                              <a href="/painel/motoristas/<%= motorista.id %>" class="btn btn-sm btn-outline">Ver
                                Detalhes</a>
                            </div>
                            <div class="data-grid-cell">
                              <% if (motorista.status==='INATIVO' ) { %>
                                <button class="btn btn-sm btn-outline" disabled>Desativar</button>
                                <% } else { %>
                                  <a href="/painel/motoristas/<%= motorista.id %>/inativar"
                                    class="btn btn-sm btn-danger"
                                    onclick="return confirm('Tem certeza que deseja inativar o motorista <%= motorista.nome %>?')">
                                    Desativar
                                  </a>
                                  <% } %>
                            </div>
                          </div>
                          <% }); %>
                            <% } else { %>
                              <div class="data-grid-row"
                                style="grid-column: 1 / -1; justify-content: center; padding: 40px; color: var(--text-muted);">
                                Nenhum motorista encontrado
                              </div>
                              <% } %>
                  </div>
                </div>

                <div class="footer-actions" style="margin-top: 1.5rem;">
                  <a href="/painel" class="btn btn-link">&larr; Voltar ao Painel</a>
                </div>
  </div>

  <%- include('../partials/footer') %>