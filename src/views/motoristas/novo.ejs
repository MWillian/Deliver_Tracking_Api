<%- include('../partials/header', { titulo: 'Novo Motorista' }) %>

  <div class="deliver-list-container">
    <div class="page-header">
      <h1>Criar Novo Motorista</h1>
      <a href="/painel/motoristas" class="btn btn-link">&larr; Voltar</a>
    </div>

    <% if (typeof erro !== 'undefined' && erro) { %>
      <div class="alert alert-danger">
        <p>
          <%= erro %>
        </p>
      </div>
    <% } %>

    <% if (typeof sucesso !== 'undefined' && sucesso) { %>
      <div class="alert alert-success">
        <p>
          <%= sucesso %>
        </p>
      </div>
    <% } %>

    <div class="form-wrapper">
      <section class="detail-card">
        <form id="form-novo-motorista" class="form-container" method="POST" action="/painel/motoristas">

          <div class="form-group">
            <label for="nome" class="detail-label">Nome:</label>
            <input type="text" id="nome" name="nome" required class="form-input" placeholder="Ex: João da Silva"
              value="<%= locals.dados?.nome || '' %>">
          </div>

          <div class="form-group">
            <label for="cpf" class="detail-label">CPF:</label>
            <input type="text" id="cpf" name="cpf" placeholder="000.000.000-00" required class="form-input"
              value="<%= locals.dados?.cpf || '' %>">
          </div>

          <div class="form-group">
            <label for="placaVeiculo" class="detail-label">Placa do Veículo:</label>
            <input type="text" id="placaVeiculo" name="placaVeiculo" placeholder="ABC-1234" required
              class="form-input" value="<%= locals.dados?.placaVeiculo || '' %>">
          </div>

          <div class="form-actions">
            <a href="/painel/motoristas" class="btn btn-outline">Cancelar</a>
            <button type="submit" id="btn-submit" class="btn btn-primary">Criar Motorista</button>
          </div>

        </form>
      </section>
    </div>
  </div>

  <%- include('../partials/footer') %>