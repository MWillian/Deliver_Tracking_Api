<%- include('../partials/header', { titulo: 'Novo Motorista' }) %>

  <div class="deliver-list-container">
    <div class="page-header">
      <h1>Criar Novo Motorista</h1>
      <a href="/painel/motoristas" class="btn btn-link">&larr; Voltar</a>
    </div>

    <div id="error-container" class="alert alert-danger" style="display: none;">
      <p id="error-message"></p>
    </div>

    <div class="form-wrapper">
      <section class="detail-card">
        <form id="form-novo-motorista" class="form-container">
          <div class="form-group">
            <label for="nome" class="detail-label">Nome:</label>
            <input type="text" id="nome" name="nome" required class="form-input" placeholder="Ex: João da Silva">
          </div>

          <div class="form-group">
            <label for="cpf" class="detail-label">CPF:</label>
            <input type="text" id="cpf" name="cpf" placeholder="000.000.000-00" required class="form-input">
          </div>

          <div class="form-group">
            <label for="placaVeiculo" class="detail-label">Placa do Veículo:</label>
            <input type="text" id="placaVeiculo" name="placaVeiculo" placeholder="ABC-1234" required class="form-input">
          </div>

          <div class="form-actions">
            <a href="/painel/motoristas" class="btn btn-outline">Cancelar</a>
            <button type="submit" id="btn-submit" class="btn btn-primary">Criar Motorista</button>
          </div>
        </form>
      </section>
    </div>
  </div>

  <%- include('../partials/footer') %>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('form-novo-motorista');

        form.addEventListener('submit', async (e) => {
          e.preventDefault();

          const btnSubmit = document.getElementById('btn-submit');
          const errorContainer = document.getElementById('error-container');
          const errorMessage = document.getElementById('error-message');

          const payload = {
            nome: document.getElementById('nome').value,
            cpf: document.getElementById('cpf').value,
            placaVeiculo: document.getElementById('placaVeiculo').value
          };

          errorContainer.style.display = 'none';
          btnSubmit.disabled = true;
          btnSubmit.textContent = 'Criando...';

          try {
            await api.post('/motoristas', payload);

            window.location.href = '/painel/motoristas?sucesso=Motorista cadastrado com sucesso';

          } catch (erro) {
            errorMessage.textContent = erro.response?.data?.erro || erro.response?.data?.message || 'Erro inesperado ao cadastrar motorista.';
            errorContainer.style.display = 'block';
          } finally {
            btnSubmit.disabled = false;
            btnSubmit.textContent = 'Criar Motorista';
          }
        });
      });
    </script>