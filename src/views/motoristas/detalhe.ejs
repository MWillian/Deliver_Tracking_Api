<%- include('../partials/header', { titulo: 'Detalhe do Motorista' }) %>

  <div class="deliver-list-container">
    <div class="page-header">
      <h1>Detalhe do Motorista #<%= motorista.id %>
      </h1>
      <a href="/painel/motoristas" class="btn btn-link">&larr; Voltar</a>
    </div>

    <% if (locals.flash && flash.sucesso && flash.sucesso.length> 0) { %>
      <div class="alert alert-success">
        <p>
          <%= flash.sucesso[0] %>
        </p>
      </div>
      <% } %>
        <% if (locals.flash && flash.erro && flash.erro.length> 0) { %>
          <div class="alert alert-danger">
            <p>
              <%= flash.erro[0] %>
            </p>
          </div>
          <% } %>

            <div>
              <section class="detail-section">
                <h2>Informações do Motorista</h2>
                <div class="detail-grid">
                  <div class="detail-item">
                    <strong>ID:</strong>
                    <p>
                      <%= motorista.id %>
                    </p>
                  </div>
                  <div class="detail-item">
                    <strong>Nome:</strong>
                    <p>
                      <%= motorista.nome %>
                    </p>
                  </div>
                  <div class="detail-item">
                    <strong>CPF:</strong>
                    <p>
                      <%= motorista.cpf %>
                    </p>
                  </div>
                  <div class="detail-item">
                    <strong>Placa:</strong>
                    <p>
                      <%= motorista.placaVeiculo %>
                    </p>
                  </div>
                  <div class="detail-item">
                    <strong>Status:</strong>
                    <p>
                      <span class="badge badge-<%= motorista.status.toLowerCase() %>">
                        <%= motorista.status %>
                      </span>
                    </p>
                  </div>
                </div>
              </section>

              <section class="detail-section">
                <h2>Histórico de Entregas</h2>

                <form class="filter-bar" method="GET" action="/painel/motoristas/<%= motorista.id %>">
                  <div class="filter-group">
                    <label for="status">Filtrar por status:</label>
                    <select id="status" name="status">
                      <option value="" <%=!locals.statusSelecionado ? 'selected' : '' %>>Todos</option>
                      <option value="CRIADA" <%=locals.statusSelecionado==='CRIADA' ? 'selected' : '' %>>CRIADA</option>
                      <option value="EM_TRANSITO" <%=locals.statusSelecionado==='EM_TRANSITO' ? 'selected' : '' %>>EM
                        TRÂNSITO</option>
                      <option value="ENTREGUE" <%=locals.statusSelecionado==='ENTREGUE' ? 'selected' : '' %>>ENTREGUE
                      </option>
                      <option value="CANCELADA" <%=locals.statusSelecionado==='CANCELADA' ? 'selected' : '' %>>CANCELADA
                      </option>
                    </select>
                  </div>
                  <button type="submit" class="btn btn-secondary">Filtrar</button>
                  <a href="/painel/motoristas/<%= motorista.id %>" class="btn btn-link">Limpar</a>
                </form>

                <div class="data-grid" style="grid-template-columns: 1fr 1fr 1fr 1fr 1fr 1fr 1fr;">
                  <div class="data-grid-header">
                    <div class="data-grid-cell-header">ID</div>
                    <div class="data-grid-cell-header">Descrição</div>
                    <div class="data-grid-cell-header">Origem</div>
                    <div class="data-grid-cell-header">Destino</div>
                    <div class="data-grid-cell-header">Status</div>
                    <div class="data-grid-cell-header">Data Criação</div>
                    <div class="data-grid-cell-header" style="text-align: right;">Ações</div>
                  </div>

                  <div id="grid-body" style="display: contents;">
                    <% if (locals.entregas && entregas.length> 0) { %>
                      <% entregas.forEach(entrega=> { %>
                        <div class="data-grid-row">
                          <div class="data-grid-cell"><strong>
                              <%= entrega.id %>
                            </strong></div>
                          <div class="data-grid-cell">
                            <%= entrega.descricao %>
                          </div>
                          <div class="data-grid-cell">
                            <%= entrega.origem %>
                          </div>
                          <div class="data-grid-cell">
                            <%= entrega.destino %>
                          </div>
                          <div class="data-grid-cell">
                            <span class="badge badge-<%= entrega.status.toLowerCase() %>">
                              <%= entrega.status.replace('_', ' ' ) %>
                            </span>
                          </div>
                          <div class="data-grid-cell">
                            <%= entrega.createdAt ? new Date(entrega.createdAt).toLocaleDateString('pt-BR') : '-' %>
                          </div>
                          <div class="data-grid-cell" style="text-align: right;">
                            <a href="/painel/entregas/<%= entrega.id %>" class="btn btn-sm btn-outline">Ver Detalhes</a>
                          </div>
                        </div>
                        <% }); %>
                          <% } else { %>
                            <div class="data-grid-row"
                              style="grid-column: 1 / -1; justify-content: center; padding: 40px; color: var(--text-muted);">
                              Nenhuma entrega encontrada para este motorista
                            </div>
                            <% } %>
                  </div>
                </div>
              </section>
            </div>
  </div>

  <%- include('../partials/footer') %>