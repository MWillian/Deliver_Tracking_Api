<%- include('../partials/header') %>

<div class="deliver-list-container" style="max-width: 500px; margin: 4rem auto;">
    <div class="page-header" style="justify-content: center; flex-direction: column; border-bottom: none;">
        <h1>Entrar</h1>
        <p style="color: var(--text-muted); margin-top: 0.5rem;">Acesse sua conta para continuar</p>
    </div>
    
    <div class="form-wrapper">
        <section class="detail-card">
            <form id="loginForm" class="form-container">
                <div class="form-group">
                    <label for="email" class="detail-label">E-mail</label>
                    <input type="email" id="email" name="email" class="form-input" required placeholder="Digite seu e-mail">
                </div>

                <div class="form-group">
                    <label for="senha" class="detail-label">Senha</label>
                    <input type="password" id="senha" name="senha" class="form-input" required placeholder="Sua senha">
                </div>

                <div id="loginError" class="alert alert-danger" style="display: none; margin-top: 1rem;"></div>

                <div class="form-actions" style="margin-top: 1.5rem; display: flex;">
                    <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">Entrar</button>
                </div>
                
                <div style="text-align: center; margin-top: 1.5rem; color: var(--text-muted);">
                    Não tem uma conta? <a href="/registrar" style="color: var(--primary-color);">Registre-se</a>
                </div>
            </form>
        </section>
    </div>
</div>

<%- include('../partials/footer') %>

<script>
document.getElementById('loginForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = e.target.querySelector('button[type="submit"]');
    const email = document.getElementById('email').value;
    const senha = document.getElementById('senha').value;
    const errorDiv = document.getElementById('loginError');
    
    errorDiv.style.display = 'none';
    btn.disabled = true;
    btn.textContent = 'Aguarde...';

    try {
        const response = await axios.post('/api/auth/login', { email, senha });
        const { accessToken, usuario } = response.data;
        
        localStorage.setItem('token', accessToken);
        localStorage.setItem('usuario', JSON.stringify(usuario));
        
        window.location.href = '/painel';
    } catch (err) {
        errorDiv.textContent = err.response?.data?.erro || 'Erro ao realizar login. Tente novamente.';
        errorDiv.style.display = 'block';
    } finally {
        btn.disabled = false;
        btn.textContent = 'Entrar';
    }
});
</script>