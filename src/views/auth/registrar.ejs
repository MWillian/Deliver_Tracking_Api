<%- include('../partials/header') %>

<div class="deliver-list-container" style="max-width: 500px; margin: 4rem auto;">
    <div class="page-header" style="justify-content: center; flex-direction: column; border-bottom: none;">
        <h1>Registrar</h1>
        <p style="color: var(--text-muted); margin-top: 0.5rem;">Crie uma nova conta</p>
    </div>
    
    <div class="form-wrapper">
        <section class="detail-card">
            <form id="registerForm" class="form-container">
                <div class="form-group">
                    <label for="nome" class="detail-label">Nome Completo</label>
                    <input type="text" id="nome" name="nome" class="form-input" required placeholder="Seu nome">
                </div>

                <div class="form-group">
                    <label for="email" class="detail-label">E-mail</label>
                    <input type="email" id="email" name="email" class="form-input" required placeholder="seu@email.com">
                </div>

                <div class="form-group">
                    <label for="senha" class="detail-label">Senha</label>
                    <input type="password" id="senha" name="senha" class="form-input" required placeholder="Sua senha forte (min. 6 chars)" minlength="6">
                </div>

                <div id="registerError" class="alert alert-danger" style="display: none; margin-top: 1rem;"></div>

                <div class="form-actions" style="margin-top: 1.5rem; display: flex;">
                    <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">Criar Conta</button>
                </div>
                
                <div style="text-align: center; margin-top: 1.5rem; color: var(--text-muted);">
                    Já tem uma conta? <a href="/login" style="color: var(--primary-color);">Entre aqui</a>
                </div>
            </form>
        </section>
    </div>
</div>

<%- include('../partials/footer') %>

<script>
document.getElementById('registerForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = e.target.querySelector('button[type="submit"]');
    const nome = document.getElementById('nome').value;
    const email = document.getElementById('email').value;
    const senha = document.getElementById('senha').value;
    const errorDiv = document.getElementById('registerError');
    
    errorDiv.style.display = 'none';
    btn.disabled = true;
    btn.textContent = 'Aguarde...';

    try {
        await axios.post('/api/auth/registrar', { nome, email, senha });
        
        alert('Conta criada com sucesso! Faça o login para acessar.');
        window.location.href = '/login';
    } catch (err) {
        errorDiv.textContent = err.response?.data?.erro || 'Erro ao registrar. Tente novamente.';
        errorDiv.style.display = 'block';
    } finally {
        btn.disabled = false;
        btn.textContent = 'Criar Conta';
    }
});
</script>