<%- include('../partials/header', { titulo: 'Atribuir Motorista' }) %>

<div class="deliver-list-container">
  <div class="page-header">
    <h1>Atribuir Motorista a Entrega</h1>
    <a href="/painel" class="btn btn-link">&larr; Voltar</a>
  </div>

  <% if (typeof sucesso !== 'undefined' && sucesso) { %>
    <div class="alert alert-success">
      <p><%= sucesso %></p>
    </div>
  <% } else if (locals.flash && flash.sucesso && flash.sucesso.length > 0) { %>
    <div class="alert alert-success">
      <p><%= flash.sucesso[0] %></p>
    </div>
  <% } %>

  <% if (typeof erro !== 'undefined' && erro) { %>
    <div class="alert alert-danger">
      <p><%= erro %></p>
    </div>
  <% } else if (locals.flash && flash.erro && flash.erro.length > 0) { %>
    <div class="alert alert-danger">
      <p><%= flash.erro[0] %></p>
    </div>
  <% } %>

  <div class="form-wrapper">
    <section class="detail-card">
      <form id="form-atribuir" class="form-container" method="POST" action="/painel/atribuir-motorista">
        <fieldset class="driver-assign-wrapper" style="border: none; padding: 0;">
          <legend class="detail-label" style="margin-bottom: 20px; font-size: 16px; font-weight: bold; color: var(--text-main);">
            Selecione a Entrega e o Motorista
          </legend>

          <div class="form-group">
            <label for="entregaId" class="detail-label">Entrega (Apenas status CRIADA):</label>
            <select id="entregaId" name="entregaId" required class="form-input">
              <% if (!locals.entregas || entregas.length === 0) { %>
                <option value="" disabled selected>Nenhuma entrega recém criada disponível</option>
              <% } else { %>
                <option value="" selected>-- Selecione uma entrega --</option>
                <% entregas.forEach(entrega => { %>
                  <option value="<%= entrega.id %>" <%= locals.dados?.entregaId == entrega.id ? 'selected' : '' %>>
                    ID <%= entrega.id %> - <%= entrega.descricao %>
                  </option>
                <% }); %>
              <% } %>
            </select>
          </div>

          <div class="form-group">
            <label for="motoristaId" class="detail-label">Motorista (Apenas ATIVOS):</label>
            <select id="motoristaId" name="motoristaId" required class="form-input">
              <% if (!locals.motoristas || motoristas.length === 0) { %>
                <option value="" disabled selected>Nenhum motorista ativo disponível</option>
              <% } else { %>
                <option value="" selected>-- Selecione um motorista --</option>
                <% motoristas.forEach(motorista => { %>
                  <option value="<%= motorista.id %>" <%= locals.dados?.motoristaId == motorista.id ? 'selected' : '' %>>
                    <%= motorista.nome %> (Placa: <%= motorista.placaVeiculo %>)
                  </option>
                <% }); %>
              <% } %>
            </select>
          </div>

          <div class="form-actions">
            <a href="/painel" class="btn btn-outline">Cancelar</a>
            <% const podeAtribuir = (locals.entregas && entregas.length > 0) && (locals.motoristas && motoristas.length > 0); %>
            <button type="submit" id="btn-submit" class="btn btn-primary" <%= !podeAtribuir ? 'disabled' : '' %>>
              Atribuir
            </button>
          </div>
        </fieldset>
      </form>
    </section>
  </div>
</div>

<%- include('../partials/footer') %>