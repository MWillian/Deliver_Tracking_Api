<%- include('../../partials/header', { titulo: 'Relatório: Motoristas Ativos' }) %>

<div class="deliver-list-container">
  <div class="page-header">
    <h1>Relatório: Motoristas Ativos com Entregas em Aberto</h1>
    <a href="/painel/relatorios" class="btn btn-link">&larr; Voltar ao Dashboard</a>
  </div>

  <div id="loading-state" style="text-align: center; padding: 2rem;">
    <p>Carregando relatório de motoristas...</p>
  </div>

  <section id="content-state" class="detail-section" style="display: none;">
    <h2>Motoristas com Entregas</h2>

    <div id="tabela-container">
      <div class="data-grid" style="grid-template-columns: 1fr 1fr 1fr 1fr 1fr 1fr 1fr;">
        <div class="data-grid-header">
          <div class="data-grid-cell-header">ID</div>
          <div class="data-grid-cell-header">Nome</div>
          <div class="data-grid-cell-header">CPF</div>
          <div class="data-grid-cell-header">Placa do Veículo</div>
          <div class="data-grid-cell-header">Status</div>
          <div class="data-grid-cell-header">Entregas em Aberto</div>
          <div class="data-grid-cell-header">Ação</div>
        </div>
        
        <div id="grid-body" style="display: contents;"></div>
      </div>

      <div style="margin-top: 30px; padding: 20px; background-color: #f9f9f9; border-radius: 4px;">
        <p><strong>Total de Motoristas Ativos:</strong> <span id="total-motoristas">-</span></p>
        <p><strong>Total de Entregas em Aberto:</strong> <strong id="total-entregas-aberto">-</strong></p>
      </div>
    </div>

    <p id="empty-state" style="color: var(--text-muted); padding: 40px; text-align: center; display: none;">
      Nenhum motorista ativo com entregas em aberto no momento.
    </p>
  </section>
</div>

<template id="row-template">
  <div class="data-grid-row">
    <div class="data-grid-cell"><strong class="cell-id"></strong></div>
    <div class="data-grid-cell cell-nome"></div>
    <div class="data-grid-cell cell-cpf"></div>
    <div class="data-grid-cell cell-placa"></div>
    <div class="data-grid-cell">
      <span class="badge cell-status"></span>
    </div>
    <div class="data-grid-cell"><strong class="cell-entregas"></strong></div>
    <div class="data-grid-cell">
      <a href="#" class="btn btn-sm btn-outline cell-link">Ver Detalhes</a>
    </div>
  </div>
</template>

<%- include('../../partials/footer') %>

<script>
document.addEventListener('DOMContentLoaded', async () => {
  const loadingState = document.getElementById('loading-state');
  const contentState = document.getElementById('content-state');
  
  const gridBody = document.getElementById('grid-body');
  const templateRow = document.getElementById('row-template');
  const tabelaContainer = document.getElementById('tabela-container');
  const emptyState = document.getElementById('empty-state');

  try {
    const response = await api.get('/relatorios/motoristas-ativos');
    const motoristas = response.data;

    if (!motoristas || motoristas.length === 0) {
      tabelaContainer.style.display = 'none';
      emptyState.style.display = 'block';
    } else {
      const totalEntregasAberto = motoristas.reduce((acc, motorista) => {
        return acc + (motorista.entregasEmAberto || 0);
      }, 0);

      document.getElementById('total-motoristas').textContent = motoristas.length;
      document.getElementById('total-entregas-aberto').textContent = totalEntregasAberto;

      motoristas.forEach(motorista => {
        const clone = templateRow.content.cloneNode(true);
        
        const idMotorista = motorista.id || motorista.motoristaId;
        const status = motorista.status || 'ATIVO';

        clone.querySelector('.cell-id').textContent = idMotorista;
        clone.querySelector('.cell-nome').textContent = motorista.nome;
        clone.querySelector('.cell-cpf').textContent = motorista.cpf || '-';
        clone.querySelector('.cell-placa').textContent = motorista.placaVeiculo || '-';
        
        const badge = clone.querySelector('.cell-status');
        badge.textContent = status;
        badge.classList.add(`badge-${status.toLowerCase()}`);
        
        clone.querySelector('.cell-entregas').textContent = motorista.entregasEmAberto || 0;
        clone.querySelector('.cell-link').href = `/painel/motoristas/${idMotorista}`;

        gridBody.appendChild(clone);
      });
    }

    loadingState.style.display = 'none';
    contentState.style.display = 'block';

  } catch (erro) {
    loadingState.innerHTML = '<p class="alert alert-danger" style="color: red;">Erro ao carregar o relatório de motoristas.</p>';
  }
});
</script>