<%- include('../../partials/header', { titulo: 'Relatório: Motoristas Ativos' }) %>

<% 
  const listaMotoristas = locals.motoristas || [];
  const totalMotoristas = listaMotoristas.length;
  
  // O mesmo reduce que estava no JS do client, agora no NodeJS
  const totalEntregasAberto = listaMotoristas.reduce((acc, motorista) => {
    return acc + (motorista.entregasEmAberto || 0);
  }, 0);
%>

<div class="deliver-list-container">
  <div class="page-header">
    <h1>Relatório: Motoristas Ativos com Entregas em Aberto</h1>
    <a href="/painel/relatorios" class="btn btn-link">&larr; Voltar ao Dashboard</a>
  </div>

  <section class="detail-section">
    <h2>Motoristas com Entregas</h2>

    <% if (totalMotoristas > 0) { %>
      <div id="tabela-container">
        <div class="data-grid" style="grid-template-columns: 1fr 1fr 1fr 1fr 1fr 1fr 1fr;">
          <div class="data-grid-header">
            <div class="data-grid-cell-header">ID</div>
            <div class="data-grid-cell-header">Nome</div>
            <div class="data-grid-cell-header">CPF</div>
            <div class="data-grid-cell-header">Placa do Veículo</div>
            <div class="data-grid-cell-header">Status</div>
            <div class="data-grid-cell-header">Entregas em Aberto</div>
            <div class="data-grid-cell-header">Ação</div>
          </div>
          
          <div id="grid-body" style="display: contents;">
            <% listaMotoristas.forEach(motorista => { 
               const idMotorista = motorista.id || motorista.motoristaId;
               const status = motorista.status || 'ATIVO';
            %>
              <div class="data-grid-row">
                <div class="data-grid-cell"><strong><%= idMotorista %></strong></div>
                <div class="data-grid-cell"><%= motorista.nome %></div>
                <div class="data-grid-cell"><%= motorista.cpf || '-' %></div>
                <div class="data-grid-cell"><%= motorista.placaVeiculo || '-' %></div>
                <div class="data-grid-cell">
                  <span class="badge badge-<%= status.toLowerCase() %>"><%= status %></span>
                </div>
                <div class="data-grid-cell"><strong><%= motorista.entregasEmAberto || 0 %></strong></div>
                <div class="data-grid-cell">
                  <a href="/painel/motoristas/<%= idMotorista %>" class="btn btn-sm btn-outline">Ver Detalhes</a>
                </div>
              </div>
            <% }); %>
          </div>
        </div>

        <div style="margin-top: 30px; padding: 20px; background-color: #f9f9f9; border-radius: 4px;">
          <p><strong>Total de Motoristas Ativos:</strong> <span><%= totalMotoristas %></span></p>
          <p><strong>Total de Entregas em Aberto:</strong> <strong><%= totalEntregasAberto %></strong></p>
        </div>
      </div>
    <% } else { %>
      <p id="empty-state" style="color: var(--text-muted); padding: 40px; text-align: center;">
        Nenhum motorista ativo com entregas em aberto no momento.
      </p>
    <% } %>
  </section>
</div>

<%- include('../../partials/footer') %>