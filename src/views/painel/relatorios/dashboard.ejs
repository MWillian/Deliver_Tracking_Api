<%- include('../../partials/header', { titulo: 'Dashboard de Relatórios' }) %>

<div class="deliver-list-container">
  <div class="page-header">
    <h1>Dashboard de Relatórios</h1>
    <a href="/painel" class="btn btn-link">&larr; Voltar</a>
  </div>

  <div>
    <section class="detail-card">
      <h2>Resumo Geral</h2>
      <div class="detail-grid">
        <div class="detail-item">
          <strong class="detail-label">Total de Entregas no sistema</strong>
          <p class="detail-value" style="font-size: 2rem; font-weight: bold; color: var(--primary);">
            <%= locals.totalEntregas || 0 %>
          </p>
        </div>

        <div class="detail-item">
          <strong class="detail-label">Motoristas Ativos com entregas atribuídas</strong>
          <p class="detail-value" style="font-size: 2rem; font-weight: bold; color: var(--primary);">
            <%= locals.totalMotoristas || 0 %>
          </p>
        </div>
      </div>
    </section>

    <section class="relatorios detail-section">
      <h2>Entregas por Status</h2>
      <div class="data-grid-dashboard">
        <div class="data-grid-header">
          <div class="data-grid-cell-header">Status</div>
          <div class="data-grid-cell-header">Quantidade</div>
          <div class="data-grid-cell-header">Ação</div>
        </div>
        
        <div class="data-grid-row">
          <div class="data-grid-cell">CRIADA</div>
          <div class="data-grid-cell"><%= locals.entregasPorStatus?.CRIADA || 0 %></div>
          <div class="data-grid-cell"><a href="/painel/entregas?status=CRIADA" class="btn btn-sm btn-outline">Ver</a></div>
        </div>
        <div class="data-grid-row">
          <div class="data-grid-cell">EM TRÂNSITO</div>
          <div class="data-grid-cell"><%= locals.entregasPorStatus?.EM_TRANSITO || 0 %></div>
          <div class="data-grid-cell"><a href="/painel/entregas?status=EM_TRANSITO" class="btn btn-sm btn-outline">Ver</a></div>
        </div>
        <div class="data-grid-row">
          <div class="data-grid-cell">ENTREGUE</div>
          <div class="data-grid-cell"><%= locals.entregasPorStatus?.ENTREGUE || 0 %></div>
          <div class="data-grid-cell"><a href="/painel/entregas?status=ENTREGUE" class="btn btn-sm btn-outline">Ver</a></div>
        </div>
        <div class="data-grid-row">
          <div class="data-grid-cell">CANCELADA</div>
          <div class="data-grid-cell"><%= locals.entregasPorStatus?.CANCELADA || 0 %></div>
          <div class="data-grid-cell"><a href="/painel/entregas?status=CANCELADA" class="btn btn-sm btn-outline">Ver</a></div>
        </div>
      </div>

      <div class="form-actions" style="margin-top: 20px; justify-content: center;">
        <a href="/painel/relatorios/entregas-por-status" class="btn btn-primary" style="width: 100%; justify-content: center;">Ver Relatório Completo</a>
      </div>
    </section>

    <section class="relatorios detail-section">
      <h2>Motoristas Ativos com entregas</h2>
      
      <% if (locals.motoristasAtivos && motoristasAtivos.length > 0) { %>
        <div id="tabela-motoristas">
          <div class="data-grid" style="grid-template-columns: 1fr 1fr 1fr 1fr 1fr;">
            <div class="data-grid-header">
              <div class="data-grid-cell-header">ID</div>
              <div class="data-grid-cell-header">Nome</div>
              <div class="data-grid-cell-header">CPF</div>
              <div class="data-grid-cell-header">Entregas em Aberto</div>
              <div class="data-grid-cell-header">Ação</div>
            </div>
            
            <div id="grid-motoristas-body" style="display: contents;">
              <% motoristasAtivos.forEach(motorista => { %>
                <% const idMotorista = motorista.motoristaId || motorista.id; %>
                <div class="data-grid-row">
                  <div class="data-grid-cell"><strong class="cell-id"><%= idMotorista %></strong></div>
                  <div class="data-grid-cell cell-nome"><%= motorista.nome %></div>
                  <div class="data-grid-cell cell-cpf"><%= motorista.cpf || '-' %></div>
                  <div class="data-grid-cell cell-entregas"><%= motorista.entregasEmAberto %></div>
                  <div class="data-grid-cell">
                    <a href="/painel/motoristas/<%= idMotorista %>" class="btn btn-sm btn-outline cell-link">Ver</a>
                  </div>
                </div>
              <% }); %>
            </div>
          </div>

          <div class="form-actions" style="margin-top: 20px; justify-content: center;">
            <a href="/painel/relatorios/motoristas-ativos" class="btn btn-primary" style="width: 100%; justify-content: center;">Ver Relatório Completo</a>
          </div>
        </div>
      <% } else { %>
        <p id="empty-motoristas" style="color: var(--text-muted);">Nenhum motorista ativo com entregas em aberto.</p>
      <% } %>
    </section>
  </div>
</div>

<%- include('../../partials/footer') %>