<%- include('../../partials/header', { titulo: 'Dashboard de Relatórios' }) %>

<div class="deliver-list-container">
  <div class="page-header">
    <h1>Dashboard de Relatórios</h1>
    <a href="/painel" class="btn btn-link">&larr; Voltar</a>
  </div>

  <div id="loading-state" style="text-align: center; padding: 2rem;">
    <p>Calculando métricas e relatórios...</p>
  </div>

  <div id="content-state" style="display: none;">
    <section class="detail-card">
      <h2>Resumo Geral</h2>
      <div class="detail-grid">
        <div class="detail-item">
          <strong class="detail-label">Total de Entregas no sistema</strong>
          <p id="total-entregas" class="detail-value" style="font-size: 2rem; font-weight: bold; color: var(--primary);">-</p>
        </div>

        <div class="detail-item">
          <strong class="detail-label">Motoristas Ativos com entregas atribuídas</strong>
          <p id="total-motoristas" class="detail-value" style="font-size: 2rem; font-weight: bold; color: var(--primary);">-</p>
        </div>
      </div>
    </section>

    <section class="relatorios detail-section">
      <h2>Entregas por Status</h2>
      <div class="data-grid-dashboard">
        <div class="data-grid-header">
          <div class="data-grid-cell-header">Status</div>
          <div class="data-grid-cell-header">Quantidade</div>
          <div class="data-grid-cell-header">Ação</div>
        </div>
        
        <div class="data-grid-row">
          <div class="data-grid-cell">CRIADA</div>
          <div id="count-criada" class="data-grid-cell">-</div>
          <div class="data-grid-cell"><a href="/painel/entregas?status=CRIADA" class="btn btn-sm btn-outline">Ver</a></div>
        </div>
        <div class="data-grid-row">
          <div class="data-grid-cell">EM TRÂNSITO</div>
          <div id="count-em_transito" class="data-grid-cell">-</div>
          <div class="data-grid-cell"><a href="/painel/entregas?status=EM_TRANSITO" class="btn btn-sm btn-outline">Ver</a></div>
        </div>
        <div class="data-grid-row">
          <div class="data-grid-cell">ENTREGUE</div>
          <div id="count-entregue" class="data-grid-cell">-</div>
          <div class="data-grid-cell"><a href="/painel/entregas?status=ENTREGUE" class="btn btn-sm btn-outline">Ver</a></div>
        </div>
        <div class="data-grid-row">
          <div class="data-grid-cell">CANCELADA</div>
          <div id="count-cancelada" class="data-grid-cell">-</div>
          <div class="data-grid-cell"><a href="/painel/entregas?status=CANCELADA" class="btn btn-sm btn-outline">Ver</a></div>
        </div>
      </div>

      <div class="form-actions" style="margin-top: 20px; justify-content: center;">
        <a href="/painel/relatorios/entregas-por-status" class="btn btn-primary" style="width: 100%; justify-content: center;">Ver Relatório Completo</a>
      </div>
    </section>

    <section class="relatorios detail-section">
      <h2>Motoristas Ativos com entregas</h2>
      
      <div id="tabela-motoristas">
        <div class="data-grid" style="grid-template-columns: 1fr 1fr 1fr 1fr 1fr;">
          <div class="data-grid-header">
            <div class="data-grid-cell-header">ID</div>
            <div class="data-grid-cell-header">Nome</div>
            <div class="data-grid-cell-header">CPF</div>
            <div class="data-grid-cell-header">Entregas em Aberto</div>
            <div class="data-grid-cell-header">Ação</div>
          </div>
          
          <div id="grid-motoristas-body" style="display: contents;"></div>
        </div>

        <div class="form-actions" style="margin-top: 20px; justify-content: center;">
          <a href="/painel/relatorios/motoristas-ativos" class="btn btn-primary" style="width: 100%; justify-content: center;">Ver Relatório Completo</a>
        </div>
      </div>

      <p id="empty-motoristas" style="color: var(--text-muted); display: none;">Nenhum motorista ativo com entregas em aberto.</p>
    </section>
  </div>
</div>

<template id="row-motorista">
  <div class="data-grid-row">
    <div class="data-grid-cell"><strong class="cell-id"></strong></div>
    <div class="data-grid-cell cell-nome"></div>
    <div class="data-grid-cell cell-cpf"></div>
    <div class="data-grid-cell cell-entregas"></div>
    <div class="data-grid-cell">
      <a href="#" class="btn btn-sm btn-outline cell-link">Ver</a>
    </div>
  </div>
</template>

<%- include('../../partials/footer') %>

<script>
document.addEventListener('DOMContentLoaded', async () => {
  const loadingState = document.getElementById('loading-state');
  const contentState = document.getElementById('content-state');
  
  const gridMotoristasBody = document.getElementById('grid-motoristas-body');
  const templateMotorista = document.getElementById('row-motorista');
  const tabelaMotoristas = document.getElementById('tabela-motoristas');
  const emptyMotoristas = document.getElementById('empty-motoristas');

  try {
    const [resStatus, resMotoristas] = await Promise.all([
      api.get('/relatorios/entregas-por-status'),
      api.get('/relatorios/motoristas-ativos')
    ]);

    const entregasStatus = resStatus.data;
    const motoristasAtivos = resMotoristas.data;

    const qtdCriada = entregasStatus.CRIADA || 0;
    const qtdEmTransito = entregasStatus.EM_TRANSITO || 0;
    const qtdEntregue = entregasStatus.ENTREGUE || 0;
    const qtdCancelada = entregasStatus.CANCELADA || 0;

    document.getElementById('count-criada').textContent = qtdCriada;
    document.getElementById('count-em_transito').textContent = qtdEmTransito;
    document.getElementById('count-entregue').textContent = qtdEntregue;
    document.getElementById('count-cancelada').textContent = qtdCancelada;

    document.getElementById('total-entregas').textContent = (qtdCriada + qtdEmTransito + qtdEntregue + qtdCancelada);
    document.getElementById('total-motoristas').textContent = motoristasAtivos.length;

    if (motoristasAtivos.length === 0) {
      tabelaMotoristas.style.display = 'none';
      emptyMotoristas.style.display = 'block';
    } else {
      motoristasAtivos.forEach(motorista => {
        const clone = templateMotorista.content.cloneNode(true);
        
        const idMotorista = motorista.motoristaId || motorista.id;
        
        clone.querySelector('.cell-id').textContent = idMotorista;
        clone.querySelector('.cell-nome').textContent = motorista.nome;
        clone.querySelector('.cell-cpf').textContent = motorista.cpf || '-'; 
        clone.querySelector('.cell-entregas').textContent = motorista.entregasEmAberto;
        clone.querySelector('.cell-link').href = `/painel/motoristas/${idMotorista}`;
        
        gridMotoristasBody.appendChild(clone);
      });
    }

    loadingState.style.display = 'none';
    contentState.style.display = 'block';

  } catch (erro) {
    loadingState.innerHTML = '<p class="alert alert-danger" style="color: red;">Erro ao carregar os dados do dashboard. Verifique sua conexão ou autenticação.</p>';
  }
});
</script>