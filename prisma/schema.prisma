generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

enum Papel {
  OPERADOR
  GESTOR
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  usuarioId Int      @map("usuario_id")
  expiresAt DateTime @map("expires_at")
  criadoEm DateTime @default(now()) @map("criado_em")
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Usuario {
  id           Int            @id @default(autoincrement())
  nome         String
  email        String         @unique
  senha        String
  papel        Papel          @default(OPERADOR)
  criadoEm    DateTime       @default(now()) @map("criado_em")
  refreshTokens RefreshToken[]
  entregas     Entrega[]

  @@map("usuarios")
}


enum StatusEntrega {
  CRIADA
  EM_TRANSITO
  ENTREGUE
  CANCELADA
}

enum StatusMotorista {
  ATIVO
  INATIVO
}

model Entrega{
  id Int @id @default(autoincrement())
  descricao String
  origem String
  destino String
  status StatusEntrega
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  criadorId Int?     @map("criador_id")
  criador   Usuario? @relation(fields: [criadorId], references: [id])

  eventos EventoEntrega[]

  @@map("entregas")
}

model Motorista{
  id Int @id @default(autoincrement())
  nome String
  placa_veiculo String
  cpf String @unique
  status StatusMotorista
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  eventos EventoEntrega[]
  
  @@map("motoristas")
}

model EventoEntrega{
  id Int @id @default(autoincrement())
  entregaId Int @map("entrega_id")
  dataEvento String @map("data_evento")
  descricao String
  motoristaId Int? @map("motorista_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  entrega Entrega @relation(fields: [entregaId], references: [id], onDelete: Cascade)
  motorista Motorista? @relation(fields: [motoristaId], references: [id])

  @@map("eventos_entrega")
}